# Copy this file to backend/.env (do NOT commit .env)

# Encryption key for storing Accept Blue credentials in the local JSON DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENC_KEY_B64=

# Backend port
PORT=8787

#+#+#+#+## Postgres
# Local (Docker): postgresql://tracer:tracer@localhost:5432/tracer_gate
# Railway: set DATABASE_URL from the Postgres plugin variables
DATABASE_URL=postgresql://tracer:tracer@localhost:15432/tracer_gate

# GHL OAuth settings
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_SHARED_SECRET=
# Must match the Redirect URI configured in your GHL Marketplace app settings
GHL_REDIRECT_URI=http://localhost:8787/auth/callback
# Location or Company depending on app target
GHL_USER_TYPE=Location

# Where to send the user after OAuth completes
APP_POST_INSTALL_REDIRECT=http://localhost:5173/

# Accept Blue
ACCEPTBLUE_BASE_URL=https://api.sandbox.accept.blue/api/v2/
ACCEPTBLUE_WEBHOOK_SIGNATURE_KEY=

# If not using Vite proxy, set allowed origin for CORS
CORS_ORIGIN=http://localhost:5173
